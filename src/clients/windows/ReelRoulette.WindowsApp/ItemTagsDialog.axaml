<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReelRoulette"
        x:Class="ReelRoulette.ItemTagsDialog"
        x:DataType="local:ItemTagsDialog"
        Title="Tag Editor"
        Width="1200"
        Height="800"
        WindowStartupLocation="Manual"
        MinWidth="400"
        MinHeight="300">
    <Grid RowDefinitions="Auto * Auto" Margin="12">
        <!-- Top Controls -->
        <Grid Grid.Row="0"
              ColumnDefinitions="* Auto Auto Auto"
              ColumnSpacing="8"
              Margin="0,0,0,12">
            <TextBlock Grid.Column="0"
                      Text="Tag Editor"
                      FontWeight="SemiBold"
                      FontSize="16"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="➕ Category"
                    Click="AddCategoryButton_Click"
                    MinWidth="100"/>
            <Button Grid.Column="2"
                    Content="🔄"
                    ToolTip.Tip="Refresh"
                    Classes="IconMomentarySmall"
                    Click="RefreshButton_Click"
                    MinWidth="36"/>
            <Button Grid.Column="3"
                    Content="❌"
                    ToolTip.Tip="Close"
                    Classes="IconMomentarySmall"
                    Click="CloseButton_Click"
                    MinWidth="36"/>
        </Grid>

        <!-- Tags by Category -->
        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,16">
            <ItemsControl x:Name="CategoriesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ItemTagsCategoryViewModel">
                        <StackPanel Margin="0,0,0,16">
                            <!-- Category Header -->
                            <Border Background="#2D2D30" Padding="8,6" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto * Auto Auto Auto Auto" ColumnSpacing="6">
                                <Button Grid.Column="0"
                                       Content="{Binding ExpandIcon}"
                                       Click="ToggleCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Padding="0"
                                       Width="24"
                                       Height="24"
                                       Margin="0,0,8,0"
                                       FontSize="14"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding CategoryName}"
                                          FontWeight="SemiBold"
                                          FontSize="14"
                                          VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                       Content="↑"
                                       Classes="IconMomentarySmall"
                                       ToolTip.Tip="Move category up"
                                       Click="MoveCategoryUpButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}"/>
                                <Button Grid.Column="3"
                                       Content="↓"
                                       Classes="IconMomentarySmall"
                                       ToolTip.Tip="Move category down"
                                       Click="MoveCategoryDownButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}"/>
                                <Button Grid.Column="4"
                                       Content="✏️"
                                       Classes="IconMomentarySmall"
                                       ToolTip.Tip="Rename category"
                                       Click="EditCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}"/>
                                <Button Grid.Column="5"
                                       Content="🗑"
                                       Classes="IconMomentarySmall"
                                       ToolTip.Tip="Delete category"
                                       Click="DeleteCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}"/>
                            </Grid>
                            </Border>

                            <!-- Tags in this category -->
                            <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding IsExpanded}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" Rows="0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:BatchTagViewModel">
                                        <Border Background="{Binding BackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="8,6"
                                                Margin="4">
                                            <Grid ColumnDefinitions="* Auto Auto Auto Auto" ColumnSpacing="6">
                                                <TextBlock Grid.Column="0"
                                                          Text="{Binding Tag}"
                                                          VerticalAlignment="Center"
                                                          FontWeight="SemiBold"/>
                                                <ToggleButton Grid.Column="1"
                                                             Content="➕"
                                                             IsChecked="{Binding IsPlusSelected}"
                                                             IsEnabled="{Binding IsSelectionEnabled}"
                                                             Classes="IconToggleSmall"
                                                             ToolTip.Tip="Add tag to all items"
                                                             Click="PlusButton_Click"/>
                                                <ToggleButton Grid.Column="2"
                                                             Content="➖"
                                                             IsChecked="{Binding IsMinusSelected}"
                                                             IsEnabled="{Binding IsSelectionEnabled}"
                                                             Classes="IconToggleSmall"
                                                             ToolTip.Tip="Remove tag from all items"
                                                             Click="MinusButton_Click"/>
                                                <Button Grid.Column="3"
                                                       Content="✏️"
                                                       Classes="IconMomentarySmall"
                                                       ToolTip.Tip="Edit tag"
                                                       Click="EditTagButton_Click"
                                                       CommandParameter="{Binding}"/>
                                                <Button Grid.Column="4"
                                                       Content="🗑"
                                                       Classes="IconMomentarySmall"
                                                       ToolTip.Tip="Delete tag"
                                                       Click="DeleteTagButton_Click"
                                                       CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add Tag Section -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto * Auto Auto"
              ColumnSpacing="8"
              Margin="0,0,0,0">
            <ComboBox x:Name="TagCategoryComboBox"
                     Grid.Column="0"
                     MinWidth="150"
                     PlaceholderText="Category"/>
            <TextBox x:Name="NewTagTextBox"
                     Grid.Column="1"
                     Watermark="New tag name"
                     KeyDown="NewTagTextBox_KeyDown"/>
            <Button Grid.Column="2"
                    Content="➕ Tag"
                    Click="AddTagButton_Click"
                    MinWidth="80"/>
            <Button x:Name="ApplyButton"
                    Grid.Column="3"
                    Content="✅️"
                    ToolTip.Tip="Apply"
                    Classes="IconMomentarySmall"
                    Click="OkButton_Click"
                    MinWidth="36"
                    IsEnabled="False"
                    IsDefault="True"/>
        </Grid>
    </Grid>
</Window>

