<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReelRoulette"
        x:Class="ReelRoulette.AutoTagDialog"
        x:DataType="local:AutoTagDialog"
        Title="Auto Tag"
        Width="820"
        Height="560"
        WindowStartupLocation="CenterOwner"
        MinWidth="620"
        MinHeight="420">
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12">
            <CheckBox Grid.Column="0"
                      x:Name="ScanFullLibraryCheckBox"
                      Content="Scan Full Library"
                      IsChecked="{Binding ScanFullLibrary}"/>
            <CheckBox Grid.Column="1"
                      x:Name="ViewAllMatchesCheckBox"
                      Content="View All Matches"
                      IsChecked="{Binding ViewAllMatches}"/>
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,8"
                   Foreground="Gray"
                   Text="Use Scan Files to find matching tags. File name matching ignores extension."/>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid RowDefinitions="Auto,Auto,*" Grid.IsSharedSizeScope="True">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" Margin="8,8,8,4" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Content="Select All"
                            Click="SelectAllButton_Click"
                            MinWidth="90"/>
                    <Button Grid.Column="1"
                            Content="Deselect All"
                            Click="DeselectAllButton_Click"
                            MinWidth="90"/>
                </Grid>
                <Grid Grid.Row="1" Margin="8,4,8,4" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ExpanderCol"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ApplyCol"/>
                        <ColumnDefinition Width="*" SharedSizeGroup="NameCol"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="TotalCol"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ChangeCol"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="" />
                    <TextBlock Grid.Column="1" Text="Apply" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Tag / File" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Total matched" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="To be changed" FontWeight="SemiBold"/>
                </Grid>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Results}" Margin="8,0,8,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:AutoTagMatchRow">
                                <Border BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,6">
                                    <Grid RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ExpanderCol"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ApplyCol"/>
                                            <ColumnDefinition Width="*" SharedSizeGroup="NameCol"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="TotalCol"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ChangeCol"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0"
                                                Grid.Column="0"
                                                Content="{Binding ExpandIcon}"
                                                Click="ToggleExpandButton_Click"
                                                CommandParameter="{Binding}"
                                                Width="24"
                                                Height="24"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"/>
                                        <CheckBox Grid.Row="0"
                                                  Grid.Column="1"
                                                  IsThreeState="True"
                                                  IsChecked="{Binding IsSelectedState}"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="{Binding TagName}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="3"
                                                   Text="{Binding TotalMatchedCount}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="4"
                                                   Text="{Binding WouldChangeCount}"
                                                   VerticalAlignment="Center"/>

                                        <ItemsControl Grid.Row="1"
                                                      Grid.Column="2"
                                                      Grid.ColumnSpan="3"
                                                      IsVisible="{Binding IsExpanded}"
                                                      ItemsSource="{Binding VisibleFiles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:AutoTagMatchedFile">
                                                    <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0" ColumnSpacing="8">
                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected}"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DisplayPath}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip.Tip="{Binding FullPath}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="StatusTextBlock"
                   Margin="0,10,0,0"
                   Foreground="Gray"
                   Text="No scan has been run yet."/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="Scan Files"
                    Click="ScanFilesButton_Click"
                    MinWidth="100"/>
            <Button Content="OK"
                    Click="OkButton_Click"
                    MinWidth="100"
                    IsDefault="True"/>
            <Button Content="Cancel"
                    Click="CancelButton_Click"
                    MinWidth="100"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
