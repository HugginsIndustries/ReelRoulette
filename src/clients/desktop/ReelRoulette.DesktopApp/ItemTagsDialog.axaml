<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReelRoulette"
        x:Class="ReelRoulette.ItemTagsDialog"
        x:DataType="local:ItemTagsDialog"
        Title="Tag Editor"
        Width="1200"
        Height="800"
        WindowStartupLocation="Manual"
        MinWidth="400"
        MinHeight="300">
    <Grid RowDefinitions="Auto * Auto" Margin="12">
        <!-- Top Controls -->
        <Grid Grid.Row="0"
              ColumnDefinitions="* Auto Auto"
              ColumnSpacing="8"
              Margin="0,0,0,12">
            <TextBlock Grid.Column="0"
                      Text="Tag Editor"
                      FontWeight="SemiBold"
                      FontSize="16"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    ToolTip.Tip="Refresh"
                    Classes="IconGlyphBase IconGlyphButton"
                    Click="RefreshButton_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="refresh"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <Button Grid.Column="2"
                    ToolTip.Tip="Close"
                    Classes="IconGlyphBase IconGlyphButton"
                    Click="CloseButton_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="close"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
        </Grid>

        <!-- Tags by Category -->
        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,16">
            <ItemsControl x:Name="CategoriesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ItemTagsCategoryViewModel">
                        <StackPanel Margin="0,0,0,16">
                            <!-- Category Header -->
                            <Border Classes="TagCategoryRowSurface" Padding="8,6" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto * Auto Auto Auto Auto" ColumnSpacing="0">
                                <Button Grid.Column="0"
                                       Classes="IconGlyphBase IconGlyphButton"
                                       Click="ToggleCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       ToolTip.Tip="Expand/collapse category">
                                    <TextBlock Classes="MaterialSymbolIcon"
                                               Text="{Binding ExpandIconSymbol}"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding CategoryName}"
                                          FontWeight="SemiBold"
                                          FontSize="14"
                                          Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                          VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                       Classes="IconGlyphBase IconGlyphButton"
                                       ToolTip.Tip="Move category up"
                                       Click="MoveCategoryUpButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}">
                                    <TextBlock Classes="MaterialSymbolIcon"
                                               Text="arrow_drop_up"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="3"
                                       Classes="IconGlyphBase IconGlyphButton"
                                       ToolTip.Tip="Move category down"
                                       Click="MoveCategoryDownButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}">
                                    <TextBlock Classes="MaterialSymbolIcon"
                                               Text="arrow_drop_down"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="4"
                                       Classes="IconGlyphBase IconGlyphButton"
                                       ToolTip.Tip="Rename category"
                                       Click="EditCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}">
                                    <TextBlock Classes="MaterialSymbolIcon"
                                               Text="edit_note"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                </Button>
                                <Button Grid.Column="5"
                                       Classes="IconGlyphBase IconGlyphButton"
                                       ToolTip.Tip="Delete category"
                                       Click="DeleteCategoryButton_Click"
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsReorderable}">
                                    <TextBlock Classes="MaterialSymbolIcon"
                                               Text="delete"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                </Button>
                            </Grid>
                            </Border>

                            <!-- Tags in this category -->
                            <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding IsExpanded}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:BatchTagViewModel">
                                        <Border Classes="TagChipSurface"
                                                Classes.state-all="{Binding IsStateAll}"
                                                Classes.state-some="{Binding IsStateSome}"
                                                Classes.state-none="{Binding IsStateNone}"
                                                Background="{Binding BackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="8,6"
                                                Margin="4"
                                                HorizontalAlignment="Left"
                                                MaxWidth="{Binding $parent[ItemsControl].Bounds.Width}">
                                            <Grid ColumnDefinitions="Auto Auto Auto Auto Auto" ColumnSpacing="0">
                                                <TextBlock Grid.Column="0"
                                                          Classes="TagChipText"
                                                          Text="{Binding Tag}"
                                                          TextWrapping="Wrap"
                                                          VerticalAlignment="Center"
                                                          FontWeight="SemiBold"/>
                                                <ToggleButton Grid.Column="1"
                                                             IsChecked="{Binding IsPlusSelected}"
                                                             IsEnabled="{Binding IsSelectionEnabled}"
                                                             Classes="IconGlyphBase IconGlyphToggle TagChipAction"
                                                             ToolTip.Tip="Add tag to all items"
                                                             Click="PlusButton_Click">
                                                    <TextBlock Classes="MaterialSymbolIcon TagChipIcon"
                                                               Text="add"
                                                               FontSize="32"
                                                               FontWeight="Bold"/>
                                                </ToggleButton>
                                                <ToggleButton Grid.Column="2"
                                                             IsChecked="{Binding IsMinusSelected}"
                                                             IsEnabled="{Binding IsSelectionEnabled}"
                                                             Classes="IconGlyphBase IconGlyphToggle TagChipAction"
                                                             ToolTip.Tip="Remove tag from all items"
                                                             Click="MinusButton_Click">
                                                    <TextBlock Classes="MaterialSymbolIcon TagChipIcon"
                                                               Text="remove"
                                                               FontSize="32"
                                                               FontWeight="Bold"/>
                                                </ToggleButton>
                                                <Button Grid.Column="3"
                                                       Classes="IconGlyphBase IconGlyphButton TagChipAction"
                                                       ToolTip.Tip="Edit tag"
                                                       Click="EditTagButton_Click"
                                                       CommandParameter="{Binding}">
                                                    <TextBlock Classes="MaterialSymbolIcon TagChipIcon"
                                                               Text="edit_note"
                                                               FontSize="32"
                                                               FontWeight="Bold"/>
                                                </Button>
                                                <Button Grid.Column="4"
                                                       Classes="IconGlyphBase IconGlyphButton TagChipAction"
                                                       ToolTip.Tip="Delete tag"
                                                       Click="DeleteTagButton_Click"
                                                       CommandParameter="{Binding}">
                                                    <TextBlock Classes="MaterialSymbolIcon TagChipIcon"
                                                               Text="delete"
                                                               FontSize="32"
                                                               FontWeight="Bold"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add Tag Section -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto Auto * Auto Auto"
              ColumnSpacing="8"
              Margin="0,0,0,0">
            <Button Grid.Column="0"
                    ToolTip.Tip="Add category"
                    Classes="IconGlyphBase IconGlyphButton"
                    Click="AddCategoryButton_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="add"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <ComboBox x:Name="TagCategoryComboBox"
                     Grid.Column="1"
                     MinWidth="150"
                     Height="36"
                     PlaceholderText="Category"/>
            <TextBox x:Name="NewTagTextBox"
                     Grid.Column="2"
                     Height="36"
                     PlaceholderText="New tag name"
                     KeyDown="NewTagTextBox_KeyDown"/>
            <Button Grid.Column="3"
                    ToolTip.Tip="Add tag"
                    Classes="IconGlyphBase IconGlyphButton"
                    Click="AddTagButton_Click"
                    Margin="0">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="add"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <Button x:Name="ApplyButton"
                    Grid.Column="4"
                    ToolTip.Tip="Apply"
                    Classes="IconGlyphBase IconGlyphButton"
                    Click="OkButton_Click"
                    IsEnabled="False"
                    IsDefault="True">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="save"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
        </Grid>
    </Grid>
</Window>

