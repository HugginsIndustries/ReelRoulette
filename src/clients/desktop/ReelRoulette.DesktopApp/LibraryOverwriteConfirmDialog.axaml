<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ReelRoulette.LibraryOverwriteConfirmDialog"
        Title="Replace Library"
        Width="440"
        Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Text="This server already has library data. Importing will replace library.json, presets, core settings, and optional thumbnail/backup data on the server. Continue?"/>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="Replace"
                    MinWidth="88"
                    IsDefault="True"
                    Click="ReplaceButton_Click"/>
            <Button Content="Cancel"
                    MinWidth="88"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
