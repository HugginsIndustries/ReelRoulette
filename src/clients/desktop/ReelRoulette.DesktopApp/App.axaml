<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReelRoulette.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <SolidColorBrush x:Key="HugginsOrangeBrush" Color="#EF7F22" />
        <SolidColorBrush x:Key="HugginsOrangeHoverBrush" Color="#F28A34" />
        <SolidColorBrush x:Key="HugginsOrangePressedBrush" Color="#D96F1E" />
        <SolidColorBrush x:Key="IconDarkGreyBrush" Color="#333333" />
        <SolidColorBrush x:Key="IconDarkGreyHoverBrush" Color="#444444" />
        <SolidColorBrush x:Key="LimeGreenBrush" Color="#22EF7F" />
        <SolidColorBrush x:Key="VioletBrush" Color="#7F22EF" />

        <!-- Shared icon button tokens -->
        <x:Double x:Key="IconGlyphButtonSize">36</x:Double>
        <x:Double x:Key="IconGlyphHoverOpacity">0.75</x:Double>
        <x:Double x:Key="IconGlyphPressedOpacity">0.55</x:Double>
        <x:Double x:Key="IconGlyphDisabledOpacity">0.45</x:Double>

    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Base icon button contract (shared by button + toggle wrappers) -->
        <Style Selector="Button.IconGlyphBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="{DynamicResource IconGlyphButtonSize}"/>
            <Setter Property="Height" Value="{DynamicResource IconGlyphButtonSize}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.IconGlyphBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="{DynamicResource IconGlyphButtonSize}"/>
            <Setter Property="Height" Value="{DynamicResource IconGlyphButtonSize}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Control-specific wrappers -->
        <Style Selector="Button.IconGlyphButton.IconGlyphBase:pointerover">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphHoverOpacity}"/>
        </Style>
        <Style Selector="Button.IconGlyphButton.IconGlyphBase:pressed">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphPressedOpacity}"/>
        </Style>
        <Style Selector="Button.IconGlyphButton.IconGlyphBase:disabled">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphDisabledOpacity}"/>
        </Style>

        <Style Selector="ToggleButton.IconGlyphToggle.IconGlyphBase:pointerover">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphHoverOpacity}"/>
        </Style>
        <Style Selector="ToggleButton.IconGlyphToggle.IconGlyphBase:pressed">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphPressedOpacity}"/>
        </Style>
        <Style Selector="ToggleButton.IconGlyphToggle.IconGlyphBase:disabled">
            <Setter Property="Opacity" Value="{DynamicResource IconGlyphDisabledOpacity}"/>
        </Style>
        <Style Selector="ToggleButton.IconGlyphToggle.IconGlyphBase:checked">
            <Setter Property="Foreground" Value="{StaticResource HugginsOrangeBrush}"/>
        </Style>

        <Style Selector="Border.TagCategoryRowSurface">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style Selector="Border.TagChipSurface">
            <Setter Property="BoxShadow" Value="0 1 3 0 #55000000"/>
        </Style>
        <Style Selector="Border.TagChipSurface.state-all">
            <Setter Property="BoxShadow" Value="0 0 0 1 #772A9C64 inset, 0 1 3 0 #55000000"/>
        </Style>
        <Style Selector="Border.TagChipSurface.state-some">
            <Setter Property="BoxShadow" Value="0 0 0 1 #77B6642A inset, 0 1 3 0 #55000000"/>
        </Style>
        <Style Selector="Border.TagChipSurface.state-none">
            <Setter Property="BoxShadow" Value="0 1 3 0 #55000000"/>
        </Style>

        <Style Selector="TextBlock.TagChipText">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Effect">
                <DropShadowEffect BlurRadius="8"
                                  OffsetX="0"
                                  OffsetY="0"
                                  Color="#9E000000"/>
            </Setter>
        </Style>

        <Style Selector="TextBlock.TagChipIcon">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Effect">
                <DropShadowEffect BlurRadius="8"
                                  OffsetX="0"
                                  OffsetY="0"
                                  Color="#9E000000"/>
            </Setter>
        </Style>

        <Style Selector="Button.TagChipAction.IconGlyphBase">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="ToggleButton.TagChipAction.IconGlyphBase">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Shared Material Symbols text style -->
        <Style Selector="TextBlock.MaterialSymbolIcon">
            <Setter Property="FontFamily" Value="/assets/fonts/MaterialSymbolsOutlined.var.ttf#Material Symbols Outlined"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Application.Styles>
</Application>