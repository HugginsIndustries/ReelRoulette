<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
    xmlns:local="clr-namespace:ReelRoulette"
    x:Class="ReelRoulette.MainWindow"
    Width="1280"
    Height="720"
    Title="ReelRoulette"
    Icon="/assets/HI.ico"
    Focusable="True">

    <Window.Styles>
        <!-- Large Toggle Button (36x36) -->
        <Style Selector="ToggleButton.IconToggleLarge">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.IconToggleLarge:pointerover:not(:checked)">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyHoverBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleLarge:pressed">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleLarge:checked">
            <Setter Property="Background" Value="{StaticResource HugginsOrangeBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangeBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleLarge:checked:pointerover">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleLarge:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Small Toggle Button (32x32) -->
        <Style Selector="ToggleButton.IconToggleSmall">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.IconToggleSmall:pointerover:not(:checked)">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyHoverBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleSmall:pressed">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleSmall:checked">
            <Setter Property="Background" Value="{StaticResource HugginsOrangeBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangeBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleSmall:checked:pointerover">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.IconToggleSmall:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Large Momentary Button (36x36) -->
        <Style Selector="Button.IconMomentaryLarge">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.IconMomentaryLarge:pointerover">
            <Setter Property="Background" Value="{StaticResource HugginsOrangeHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangeHoverBrush}"/>
        </Style>
        <Style Selector="Button.IconMomentaryLarge:pressed">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="Button.IconMomentaryLarge:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Small Momentary Button (32x32) -->
        <Style Selector="Button.IconMomentarySmall">
            <Setter Property="Background" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IconDarkGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.IconMomentarySmall:pointerover">
            <Setter Property="Background" Value="{StaticResource HugginsOrangeHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangeHoverBrush}"/>
        </Style>
        <Style Selector="Button.IconMomentarySmall:pressed">
            <Setter Property="Background" Value="{StaticResource HugginsOrangePressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HugginsOrangePressedBrush}"/>
        </Style>
        <Style Selector="Button.IconMomentarySmall:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <Style Selector="ListBox#LibraryGridListBox ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox Button:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#LibraryGridListBox Button:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Library panel: use fixed, non-overlay vertical scrollbars -->
        <Style Selector="ListBox#LibraryListBox">
            <Setter Property="ScrollViewer.AllowAutoHide" Value="False"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible"/>
        </Style>
        <Style Selector="ListBox#LibraryListBox ScrollBar:vertical">
            <Setter Property="Width" Value="14"/>
            <Setter Property="MinWidth" Value="14"/>
        </Style>
        <Style Selector="ScrollViewer#LibraryGridScrollViewer">
            <Setter Property="AllowAutoHide" Value="False"/>
        </Style>
        <Style Selector="ScrollViewer#LibraryGridScrollViewer ScrollBar:vertical">
            <Setter Property="Width" Value="14"/>
            <Setter Property="MinWidth" Value="14"/>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="0">
        <!-- Row 0: Menu bar -->
        <Menu x:Name="MainMenu" Grid.Row="0">
            <MenuItem Header="_Playback">
                <MenuItem x:Name="KeepPlayingMenuItem"
                          Header="Keep Playing (Timer)"
                          ToggleType="CheckBox"
                          Click="KeepPlayingMenuItem_Click"/>
                <MenuItem Header="Set Interval"
                          Click="SetIntervalMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Clear Playback Stats"
                          Click="ClearPlaybackStats_Click"/>
            </MenuItem>
            <MenuItem x:Name="LibraryMenuItem"
                      Header="_Library">
                <MenuItem x:Name="ImportFolderMenuItem"
                          Header="Import Folder"
                          Click="ImportFolderMenuItem_Click"/>
                <MenuItem Header="Export Library…"
                          Click="ExportLibraryMenuItem_Click"/>
                <MenuItem Header="Import Library…"
                          Click="ImportLibraryMenuItem_Click"/>
                <MenuItem Header="Auto Tag"
                          Click="AutoTagMenuItem_Click"/>
                <MenuItem x:Name="ManageSourcesMenuItem"
                          Header="Manage Sources"
                          Click="ManageSourcesMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="ShowMenuMenuItem"
                          Header="Show Menu (1)"
                          ToggleType="CheckBox"
                          IsChecked="True"
                          Click="ShowMenuMenuItem_Click"/>
                <MenuItem x:Name="ShowStatusMenuItem"
                          Header="Show Status Line (2)"
                          ToggleType="CheckBox"
                          IsChecked="True"
                          Click="ShowStatusMenuItem_Click"/>
                <MenuItem x:Name="ShowControlsMenuItem"
                          Header="Show Controls (3)"
                          ToggleType="CheckBox"
                          IsChecked="True"
                          Click="ShowControlsMenuItem_Click"/>
                <MenuItem x:Name="ShowLibraryPanelMenuItem"
                          Header="Show Library Panel (4)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="ShowLibraryPanelMenuItem_Click"/>
                <MenuItem x:Name="ShowStatsMenuItem"
                          Header="Show Stats Panel (5)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="ShowStatsMenuItem_Click"/>
                <MenuItem Header="Show FFmpeg Logs"
                          Click="ShowFFmpegLogsMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="FullscreenMenuItem"
                          Header="Fullscreen (F11)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="FullscreenMenuItem_Click"/>
                <MenuItem x:Name="AlwaysOnTopMenuItem"
                          Header="Always On Top"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="AlwaysOnTopMenuItem_Click"/>
                <MenuItem x:Name="PlayerViewModeMenuItem"
                          Header="Player View Mode (P)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="PlayerViewModeMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Settings (S)"
                          Click="SettingsMenuItem_Click"/>
                <MenuItem Header="Diagnostics"
                          Click="DiagnosticsMenuItem_Click"/>
                <MenuItem x:Name="OpenWebUiMenuItem"
                          Header="Open Web UI"
                          Click="OpenWebUiMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Row 1: Status line -->
        <Grid x:Name="StatusLineGrid" Grid.Row="1" Margin="10,5,10,5" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0"
                  MinHeight="18"
                  VerticalAlignment="Center">
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="11"
                           Foreground="Gray"
                           VerticalAlignment="Center"/>
                <ProgressBar x:Name="StatusLibraryArchiveProgressBar"
                             Height="6"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="False"
                             MinWidth="80"/>
            </Grid>
            <TextBlock x:Name="StatusTimeTextBlock"
                       Grid.Column="1"
                       FontSize="11"
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       Text="00:00:00.000"
                       HorizontalAlignment="Right"
                       Margin="8,0,0,0"/>
        </Grid>

        <!-- Row 2: Controls row -->
        <Grid x:Name="ControlsRow"
              Grid.Row="2"
              Margin="10,0,10,0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Previous button -->
            <Button x:Name="PreviousButton"
                    Grid.Column="7"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Previous (←)"
                    Margin="0"
                    Click="PreviousButton_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="skip_previous"
                           FontSize="36"
                           FontWeight="Bold"/>
            </Button>
            <!-- Play/Pause button -->
            <ToggleButton x:Name="PlayPauseButton"
                          Grid.Column="8"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Play / Pause (K or Space)"
                          Margin="0"
                          Click="PlayPauseButton_Click">
                <TextBlock
                           Classes="MaterialSymbolIcon"
                           Text="play_pause"
                           FontSize="36"
                           FontWeight="Bold"/>
            </ToggleButton>
            <!-- Next button -->
            <Button x:Name="NextButton"
                    Grid.Column="9"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Next (→)"
                    Margin="0"
                    Click="NextButton_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="skip_next"
                           FontSize="36"
                           FontWeight="Bold"/>
            </Button>
            <!-- Play Random button -->
            <Button x:Name="PlayRandomButton"
                    Grid.Column="0"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Play random media (R)"
                    Margin="0,0,8,0"
                    Click="PlayRandom_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="casino"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <!-- Filter button -->
            <Button x:Name="FilterButton"
                    Grid.Column="1"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Select filters..."
                    Margin="0,0,8,0"
                    Click="FilterMenuItem_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="filter_alt"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <!-- Manage tags button -->
            <Button x:Name="ManageTagsButton"
                    Grid.Column="2"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Edit tags... (T)"
                    Margin="0,0,8,0"
                    Click="ManageTagsForCurrentVideo_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="tag"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <!-- Show in file manager button -->
            <Button x:Name="ShowInFileManagerButton"
                    Grid.Column="3"
                    Classes="IconGlyphBase IconGlyphButton"
                    ToolTip.Tip="Show current media in file manager..."
                    Margin="0,0,8,0"
                    Click="ShowCurrentVideoInFileManager_Click">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="folder_open"
                           FontSize="32"
                           FontWeight="Bold"/>
            </Button>
            <!-- Loop toggle -->
            <ToggleButton x:Name="LoopToggle"
                          Grid.Column="4"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Loop"
                          IsChecked="True"
                          Margin="0,0,8,0"
                          IsCheckedChanged="LoopToggle_Changed">
                <TextBlock x:Name="LoopGlyph"
                           Classes="MaterialSymbolIcon"
                           Text="repeat_one"
                           FontSize="32"
                           FontWeight="Bold"/>
            </ToggleButton>
            <!-- Auto-play next toggle -->
            <ToggleButton x:Name="AutoPlayNextCheckBox"
                          Grid.Column="5"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Auto-play next (A)"
                          IsChecked="True"
                          Margin="0"
                          IsCheckedChanged="AutoPlayNext_Changed">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="autoplay"
                           FontSize="32"
                           FontWeight="Bold"/>
            </ToggleButton>
            <!-- Seek bar -->
            <Slider x:Name="SeekSlider"
                    Grid.Column="11"
                    MinWidth="200"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    IsEnabled="False"
                    Margin="0,0,8,0"
                    PointerPressed="SeekSlider_PointerPressed"
                    PointerReleased="SeekSlider_PointerReleased"
                    PointerCaptureLost="SeekSlider_PointerCaptureLost"
                    ValueChanged="SeekSlider_ValueChanged">
                <ToolTip.Tip>
                    <StackPanel>
                        <Image x:Name="SeekSliderThumbnail" 
                               Width="160" 
                               Height="90" 
                               Stretch="Uniform"
                               IsVisible="False"
                               Margin="0,0,0,4"/>
                        <TextBlock x:Name="SeekSliderTimeText" 
                                   Text="00:00"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToolTip.Tip>
            </Slider>
            <!-- Favorite toggle -->
            <ToggleButton x:Name="FavoriteToggle"
                          Grid.Column="12"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Favorite (F)"
                          Margin="0,0,8,0"
                          IsCheckedChanged="FavoriteToggle_Changed">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="favorite"
                           FontSize="32"
                           FontWeight="Bold"/>
            </ToggleButton>
            <!-- Blacklist toggle -->
            <ToggleButton x:Name="BlacklistToggle"
                          Grid.Column="13"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Blacklist (B)"
                          Margin="0,0,8,0"
                          IsCheckedChanged="BlacklistToggle_Changed">
                <TextBlock Classes="MaterialSymbolIcon"
                           Text="thumb_down"
                           FontSize="32"
                           FontWeight="Bold"/>
            </ToggleButton>
            <!-- Volume slider -->
            <Slider x:Name="VolumeSlider"
                    Grid.Column="14"
                    Width="120"
                    Minimum="0"
                    Maximum="200"
                    Value="100"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    ValueChanged="VolumeSlider_ValueChanged"
                    PointerWheelChanged="VolumeSlider_PointerWheelChanged"
                    PointerReleased="VolumeSlider_PointerReleased"
                    PointerCaptureLost="VolumeSlider_PointerCaptureLost"/>
            <!-- Mute button -->
            <ToggleButton x:Name="MuteButton"
                          Grid.Column="15"
                          Classes="IconGlyphBase IconGlyphToggle"
                          ToolTip.Tip="Mute / Unmute (M)"
                          IsCheckedChanged="MuteButton_IsCheckedChanged">
                <TextBlock x:Name="MuteGlyph"
                           Classes="MaterialSymbolIcon"
                           Text="volume_up"
                           FontSize="32"
                           FontWeight="Bold"
                           />
            </ToggleButton>

            <!-- Hidden controls kept for logic (driven via menus/dialogs) -->
            <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="False">
                <NumericUpDown x:Name="IntervalNumericUpDown"
                               Minimum="1"
                               Maximum="3600"
                               Value="60"/>
                <Button x:Name="KeepPlayingButton"
                        Content="Keep Playing"
                        Click="KeepPlaying_Click"/>
            </StackPanel>
        </Grid>

        <!-- Row 3: Three-column layout with Library panel, Video, and Stats panel -->
        <!-- Columns: 0:Library(Auto) 1:Splitter(4) 2:Video(*) 3:Stats(Auto) -->
        <Border x:Name="MainContentGridBorder" Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="Gray">
            <Grid x:Name="MainContentGrid" Margin="0" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="400"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            <!-- Column 0: Library Panel -->
            <Border x:Name="LibraryPanelContainer"
                    Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="0,0,1,0"
                    Padding="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    SizeChanged="LibraryPanelContainer_SizeChanged"
                    IsVisible="False">
                <Grid RowDefinitions="Auto Auto Auto Auto Auto Auto Auto *" VerticalAlignment="Stretch" x:DataType="local:MainWindow">
                    <!-- Row 0: Library info header -->
                    <TextBlock x:Name="LibraryInfoTextBlock"
                              Grid.Row="0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,0,0,8"
                              Text="{Binding LibraryInfoText}"/>
                    
                    <!-- Row 1: Filter/Selection count display -->
                    <TextBlock x:Name="LibraryCountTextBlock"
                              Grid.Row="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,0,0,8"
                              Text="🎯 0 filtered • 📝 0 selected"/>
                    
                    <!-- Row 2: Filters row -->
                    <Grid Grid.Row="2" ColumnDefinitions="* Auto Auto" ColumnSpacing="4" Margin="0,0,0,8">
                        <TextBlock x:Name="LibraryFilterSummaryTextBlock"
                                 Grid.Column="0"
                                 VerticalAlignment="Center"
                                 Text="{Binding FilterSummaryText}"/>
                        <ToggleButton x:Name="LibraryGridViewToggle"
                                    Grid.Column="1"
                                    Classes="IconGlyphBase IconGlyphToggle"
                                    ToolTip.Tip="Grid view"
                                    IsCheckedChanged="LibraryGridViewToggle_Changed">
                            <TextBlock Classes="MaterialSymbolIcon"
                                       Text="gallery_thumbnail"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                        </ToggleButton>
                        <Button x:Name="LibraryFilterButton"
                               Grid.Column="2"
                               Classes="IconGlyphBase IconGlyphButton"
                               ToolTip.Tip="Select filters..."
                               Margin="0,0,4,0"
                               Click="LibraryFilterButton_Click">
                            <TextBlock Classes="MaterialSymbolIcon"
                                       Text="filter_alt"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                        </Button>
                    </Grid>
                    
                    <!-- Row 3: Filter Preset selection -->
                    <ComboBox x:Name="LibraryPresetComboBox"
                             Grid.Row="3"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,8"
                             SelectionChanged="LibraryPresetComboBox_SelectionChanged">
                        <!-- Items will be populated in code-behind -->
                    </ComboBox>

                    <!-- Row 4: Randomization mode selection -->
                    <ComboBox x:Name="LibraryRandomizationModeComboBox"
                             Grid.Row="4"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,8"
                             SelectionChanged="LibraryRandomizationModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Pure Random" Tag="PureRandom"/>
                        <ComboBoxItem Content="Weighted Random" Tag="WeightedRandom"/>
                        <ComboBoxItem Content="Smart Shuffle" Tag="SmartShuffle"/>
                        <ComboBoxItem Content="Spread Mode" Tag="SpreadMode"/>
                        <ComboBoxItem Content="Weighted with Spread" Tag="WeightedWithSpread"/>
                    </ComboBox>
                    
                    <!-- Row 5: Sort controls -->
                    <Grid Grid.Row="5" ColumnDefinitions="* Auto" ColumnSpacing="8" Margin="0,0,0,8">
                        <ComboBox x:Name="LibrarySortComboBox"
                                 Grid.Column="0"
                                 HorizontalAlignment="Stretch"
                                 SelectionChanged="LibrarySortComboBox_SelectionChanged">
                            <ComboBoxItem Content="Name" Tag="Name"/>
                            <ComboBoxItem Content="Last played" Tag="LastPlayed"/>
                            <ComboBoxItem Content="Play count" Tag="PlayCount"/>
                            <ComboBoxItem Content="Duration" Tag="Duration"/>
                        </ComboBox>
                        <Button x:Name="LibrarySortDirectionButton"
                                Grid.Column="1"
                                MinWidth="128"
                                HorizontalAlignment="Right"
                                Click="LibrarySortDirectionButton_Click"/>
                    </Grid>
                    
                    <!-- Row 6: Search box -->
                    <TextBox x:Name="LibrarySearchTextBox"
                            Grid.Row="6"
                            PlaceholderText="Search..."
                            Margin="0,0,0,8"
                            TextChanged="LibrarySearchTextBox_TextChanged"/>
                    
                    <!-- Row 7: Items list (virtualized) -->
                    <ListBox x:Name="LibraryListBox"
                             Grid.Row="7"
                             VerticalAlignment="Stretch"
                             SelectionMode="Multiple"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.AllowAutoHide="False"
                             ScrollViewer.VerticalScrollBarVisibility="Visible"
                             IsVisible="True"
                             DoubleTapped="LibraryListBox_DoubleTapped"
                             KeyDown="LibraryListBox_KeyDown"
                             SelectionChanged="LibraryListBox_SelectionChanged"
                             PointerPressed="LibraryListBox_PointerPressed">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add to Favorites"
                                         Click="ContextMenu_AddToFavorites_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="★"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="ContextMenu_RemoveFromFavoritesMenuItem"
                                         Header="Remove from Favorites"
                                         Click="ContextMenu_RemoveFromFavorites_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="★"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Add to Blacklist"
                                         Click="ContextMenu_AddToBlacklist_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="👎"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="ContextMenu_RemoveFromBlacklistMenuItem"
                                         Header="Remove from Blacklist"
                                         Click="ContextMenu_RemoveFromBlacklist_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="👎"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Add Tags..."
                                         Click="ContextMenu_AddTags_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🏷️"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="ContextMenu_RemoveTagsMenuItem"
                                         Header="Remove Tags..."
                                         Click="ContextMenu_RemoveTags_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🏷️"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Remove from Library"
                                         Click="ContextMenu_RemoveFromLibrary_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🗑️"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Clear Playback Stats"
                                         Click="ContextMenu_ClearStats_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="📊"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="local:LibraryItemViewModel">
                                <Grid ColumnDefinitions="* Auto Auto" Margin="0,4,16,4">
                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Blacklist indicator (shown if blacklisted) -->
                                            <TextBlock Grid.Column="0"
                                                       Text="👎"
                                                       FontSize="14"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsBlacklisted}"/>
                                            <!-- Favorite indicator (shown if favorite) -->
                                            <TextBlock Grid.Column="1"
                                                       Text="⭐"
                                                       FontSize="14"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsFavorite}"/>
                                            <!-- File name -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FileName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="{Binding FullPath}"
                                                   FontSize="10"
                                                   Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="IconGlyphBase IconGlyphButton"
                                            Margin="4,0,2,0"
                                            ToolTip.Tip="Play this video"
                                            Tag="{Binding FullPath}"
                                            Click="LibraryItemPlay_Click">
                                        <TextBlock Classes="MaterialSymbolIcon"
                                                   Text="play_arrow"
                                                   FontSize="32"
                                                   FontWeight="Bold"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Classes="IconGlyphBase IconGlyphButton"
                                            Margin="2,0,2,0"
                                            ToolTip.Tip="Show in file manager"
                                            Tag="{Binding FullPath}"
                                            Click="LibraryItemShowInFileManager_Click">
                                        <TextBlock Classes="MaterialSymbolIcon"
                                                   Text="folder_open"
                                                   FontSize="32"
                                                   FontWeight="Bold"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer x:Name="LibraryGridScrollViewer"
                                  Grid.Row="7"
                                  VerticalAlignment="Stretch"
                                  AllowAutoHide="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Visible"
                                  ScrollChanged="LibraryGridScrollViewer_ScrollChanged"
                                  PointerPressed="LibraryGridScrollViewer_PointerPressed"
                                  PointerReleased="LibraryGridScrollViewer_PointerReleased"
                                  PointerCaptureLost="LibraryGridScrollViewer_PointerCaptureLost"
                                  IsVisible="False">
                        <StackPanel Orientation="Vertical">
                            <Border Height="{Binding LibraryGridTopSpacerHeight}"/>
                            <ItemsControl x:Name="LibraryGridItemsControl"
                                          ItemsSource="{Binding LibraryGridVisibleRows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="local:LibraryGridRowViewModel">
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="0,0,0,1">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="local:LibraryGridTileViewModel">
                                                    <Button Tag="{Binding Item.FullPath}"
                                                            Click="LibraryGridItem_Click"
                                                            Width="{Binding TileWidth}"
                                                            Height="{Binding TileHeight}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch">
                                                        <Grid>
                                                            <Border Background="#22000000"
                                                                    CornerRadius="0"
                                                                    ClipToBounds="True">
                                                                <Image Source="{Binding Item.ThumbnailBitmap}"
                                                                       Stretch="UniformToFill"/>
                                                            </Border>
                                                            <Border HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="4"
                                                                    Background="#99000000"
                                                                    CornerRadius="4"
                                                                    Padding="3,2"
                                                                    IsVisible="{Binding Item.HasGridStateIndicator}">
                                                                <StackPanel Orientation="Horizontal"
                                                                            Spacing="4">
                                                                    <TextBlock Classes="MaterialSymbolIcon"
                                                                               Text="favorite"
                                                                               FontSize="18"
                                                                               Foreground="{StaticResource HugginsOrangeBrush}"
                                                                               IsVisible="{Binding Item.IsFavorite}"/>
                                                                    <TextBlock Classes="MaterialSymbolIcon"
                                                                               Text="thumb_down"
                                                                               FontSize="18"
                                                                               Foreground="{StaticResource HugginsOrangeBrush}"
                                                                               IsVisible="{Binding Item.IsBlacklisted}"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border VerticalAlignment="Bottom"
                                                                    Background="#AA000000"
                                                                    CornerRadius="0"
                                                                    Padding="6,3">
                                                                <TextBlock Text="{Binding Item.FileName}"
                                                                           MaxLines="1"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="White"
                                                                           FontSize="12"/>
                                                            </Border>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Height="{Binding LibraryGridBottomSpacerHeight}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Column 1: Splitter between Library and Video -->
            <GridSplitter x:Name="LibraryVideoSplitter"
                         Grid.Column="1"
                         Width="4"
                         ResizeDirection="Columns"
                         ResizeBehavior="PreviousAndNext"
                         Background="Gray"
                         IsVisible="False"/>

            <!-- Column 2: Video View Container -->
            <Border x:Name="VideoViewContainer"
                    Grid.Column="2"
                    BorderBrush="Gray"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- VideoView for videos -->
                    <vlc:VideoView x:Name="VideoView"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   PointerWheelChanged="VideoView_PointerWheelChanged"/>
                    
                    <!-- Image overlay for photos -->
                    <Image x:Name="PhotoImageView"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Stretch="Uniform"
                           IsVisible="False"/>
                </Grid>
            </Border>

            <!-- Column 3: Stats Panel -->
            <Border x:Name="StatsPanelContainer"
                    Grid.Column="3"
                    BorderBrush="Gray"
                    BorderThickness="0"
                    Padding="8"
                    MinWidth="290"
                    MaxWidth="290"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsVisible="False">
                <Grid RowDefinitions="Auto *" VerticalAlignment="Stretch">
                    <TextBlock Text="Global Stats"
                               Grid.Row="0"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalAlignment="Stretch">
                        <StackPanel Spacing="8" x:DataType="local:MainWindow">
                            <!-- Library Totals -->
                            <TextBlock Text="Library Totals"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding GlobalTotalVideosKnown, StringFormat='Total videos: {0}'}"/>
                            <TextBlock Text="{Binding GlobalTotalPhotosKnown, StringFormat='Total photos: {0}'}"/>
                            <TextBlock Text="{Binding GlobalTotalMediaKnown, StringFormat='Total media: {0}'}"/>
                            <TextBlock Text="{Binding GlobalFavoritesCount, StringFormat='Favorites: {0}'}"/>
                            <TextBlock Text="{Binding GlobalBlacklistCount, StringFormat='Blacklisted: {0}'}"/>
                            
                            <!-- Playback Statistics -->
                            <TextBlock Text="Playback Statistics"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="{Binding GlobalTotalPlays, StringFormat='Total plays (all time): {0}'}"/>
                            <TextBlock Text="{Binding GlobalUniqueMediaPlayed, StringFormat='Unique played media: {0}'}"/>
                            <TextBlock Text="{Binding GlobalNeverPlayedMediaKnown, StringFormat='Never played media: {0}'}"/>
                            
                            <!-- Video Audio Stats -->
                            <TextBlock Text="Video Audio Stats"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="{Binding GlobalVideosWithAudio, StringFormat='Videos with audio: {0}'}"/>
                            <TextBlock Text="{Binding GlobalVideosWithoutAudio, StringFormat='Videos without audio: {0}'}"/>
                            <TextBlock Text="{Binding GlobalBaselineLoudnessDisplay, StringFormat='Baseline loudness: {0}'}"/>
                            
                            <!-- Current File Stats Section -->
                            <TextBlock Text="Current File"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,16,0,8"/>
                            <TextBlock Text="{Binding CurrentVideoFileName, StringFormat='File: {0}'}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentVideoFullPath}"
                                       FontSize="10"
                                       Foreground="Gray"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentVideoPlayCount, StringFormat='Plays: {0}'}"/>
                            <TextBlock Text="{Binding CurrentVideoLastPlayedDisplay, StringFormat='Last played: {0}'}"/>
                            <TextBlock Text="{Binding CurrentVideoIsFavoriteDisplay, StringFormat='Favorite: {0}'}"/>
                            <TextBlock Text="{Binding CurrentVideoIsBlacklistedDisplay, StringFormat='Blacklisted: {0}'}"/>
                            <TextBlock Text="{Binding CurrentVideoDurationDisplay, StringFormat='Duration: {0}'}"
                                       IsVisible="{Binding IsCurrentFileVideo}"/>
                            <TextBlock Text="{Binding CurrentVideoHasAudioDisplay, StringFormat='Has audio: {0}'}"
                                       IsVisible="{Binding IsCurrentFileVideo}"/>
                            <TextBlock Text="{Binding CurrentVideoLoudnessDisplay, StringFormat='Loudness: {0}'}"
                                       IsVisible="{Binding IsCurrentFileVideo}"/>
                            <TextBlock Text="{Binding CurrentVideoLoudnessAdjustmentDisplay, StringFormat='Adjustment: {0}'}"
                                       IsVisible="{Binding IsCurrentFileVideo}"/>
                            <TextBlock Text="{Binding CurrentVideoPeakDisplay, StringFormat='Peak: {0}'}"
                                       IsVisible="{Binding IsCurrentFileVideo}"/>
                            <TextBlock Text="{Binding CurrentVideoTagsDisplay}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
