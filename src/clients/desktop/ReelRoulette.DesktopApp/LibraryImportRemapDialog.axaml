<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ReelRoulette.LibraryImportRemapDialog"
        Title="Import Library — Map Folders"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterOwner"
        MinWidth="560"
        MinHeight="360">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Text="Each media source folder from the export must be mapped to a folder on this computer, or marked Skip (library keeps original paths; media appears offline until you fix paths)."/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RowsPanel" Spacing="12"/>
        </ScrollViewer>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button x:Name="ConfirmButton"
                    Content="Upload import…"
                    MinWidth="120"
                    IsDefault="True"
                    Click="ConfirmButton_Click"/>
            <Button Content="Cancel"
                    MinWidth="88"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
